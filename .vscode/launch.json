{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run Server (server.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": true
        },
        {
            "name": "Python: Run Streamlit App (app.py)",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/app.py",
                "--server.port",
                "8501"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "justMyCode": true
        }
    ]
}
